<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="JNI Demo — NDK Android"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#3F51B5"
            android:padding="16dp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Démo 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="① helloFromJNI()"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvResult1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textSize="16sp"
            android:textColor="#2E7D32"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"/>

        <!-- Démo 2 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="② computeFactorial(10)"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvResult2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textSize="16sp"
            android:textColor="#1565C0"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"/>

        <!-- Démo 3 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="③ reverseString(\"Android JNI\")"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvResult3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textSize="16sp"
            android:textColor="#6A1B9A"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"/>

        <!-- Démo 4 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="④ processArray({3,17,8,42,5,99,11})"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvResult4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textSize="16sp"
            android:textColor="#E65100"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"/>

        <!-- Note NDK -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Voir Logcat (tag: JNIDemo) pour les logs C++"
            android:textSize="12sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
